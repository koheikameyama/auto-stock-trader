# このファイルを .env にコピーして値を設定した後、`npx dotenvx encrypt` で暗号化すること。
# 値の確認は `npx dotenvx get <KEY>`、変更は `npx dotenvx set <KEY> <value>`。
# .env（暗号化済み）と .env.keys（復号鍵）はどちらも git にコミットしない。
# 詳細は README「.env の暗号化（dotenvx）」を参照。

# Database
DATABASE_URL="postgresql://username:password@host:port/database"

# Authentication & Dashboard
BASIC_AUTH_USER="admin"
BASIC_AUTH_PASS="your-password"
DASHBOARD_TOKEN="your-secret-token"
APP_URL="https://your-app.example.com"

# Broker (Tachibana) & Market Data
# v4r9: 認証は利用設定画面で発行する認証ID(sAuthId)と公開鍵暗号方式。
# TACHIBANA_PRIVATE_KEY は登録した公開鍵と対になる秘密鍵(PEM)。
# 改行を避けるため PEM 全体を Base64 エンコードした値も指定可。
TACHIBANA_ENV="demo"
TACHIBANA_AUTH_ID=""
TACHIBANA_PRIVATE_KEY=""
TACHIBANA_SECOND_PASSWORD=""

# OpenAI
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_ADMIN_KEY="sk-admin-your-openai-admin-key"

# Langfuse
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_BASE_URL="https://us.cloud.langfuse.com"

# Slack
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/xxx/xxx/xxx"
OPENAI_COST_SLACK_WEBHOOK_URL="https://hooks.slack.com/services/xxx/xxx/xxx"
# SNS投稿（morning/daily-social-post）通知の専用webhook。未設定なら SLACK_WEBHOOK_URL に送信
SNS_POST_SLACK_WEBHOOK_URL="https://hooks.slack.com/services/xxx/xxx/xxx"

# Email (Resend) — 先行案内リスト登録の確認メール。未設定なら送信スキップ(no-op)
RESEND_API_KEY=""
MAIL_FROM="相場局面モニター <noreply@stock-buddy.net>"

# External Services & Proxies
YFINANCE_PROXY=""
GITHUB_PAT=""
CRONJOB_API_KEY=""