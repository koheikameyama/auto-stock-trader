// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 銘柄マスタ
model Stock {
  id         String  @id @default(cuid())
  tickerCode String  @unique // "7203.T"
  name       String
  market     String // "東証プライム" etc.
  sector     String?

  // 財務指標
  marketCap     Decimal? // 時価総額（億円）
  dividendYield Decimal? // 配当利回り（%）
  pbr           Decimal? @db.Decimal(8, 2)
  per           Decimal? @db.Decimal(8, 2)
  roe           Decimal? @db.Decimal(8, 4)
  eps           Decimal? @db.Decimal(12, 2)
  isProfitable  Boolean?

  // 最新株価データ
  latestPrice     Decimal?  @db.Decimal(12, 2)
  latestVolume    BigInt?
  dailyChangeRate Decimal?  @db.Decimal(8, 2)
  weekChangeRate  Decimal?  @db.Decimal(8, 2)
  volatility      Decimal?  @db.Decimal(8, 2)
  atr14           Decimal?  @db.Decimal(12, 2)
  latestPriceDate DateTime? @db.Date
  priceUpdatedAt  DateTime?

  // コーポレートイベント管理（即死ルール用）
  nextEarningsDate DateTime? @db.Date  // 次回決算発表予定日
  exDividendDate   DateTime? @db.Date           // 次回配当権利落ち日
  dividendPerShare Decimal?  @db.Decimal(10, 2) // 1株あたり配当金額（円）

  // 上場廃止管理
  fetchFailCount Int      @default(0)
  isDelisted     Boolean  @default(false)

  // JPX CSV同期
  isActive        Boolean   @default(true)  // JPX上場銘柄CSVに存在するか
  jpxSectorCode   String?                   // JPX 33業種コード
  jpxSectorName   String?                   // JPX 33業種区分名
  jpxLastSyncDate DateTime? @db.Date        // 最後にJPX CSVに出現した日付

  // 廃止予定管理
  delistingDate DateTime? @db.Date         // 上場廃止予定日
  isRestricted  Boolean   @default(false)  // 取引制限フラグ

  // 動的防御（立花API用、将来実装）
  supervisionFlag String?                  // "監理" | "整理" | null
  tradingHaltFlag Boolean  @default(false) // 売買停止
  statusUpdatedAt DateTime?                // ステータス最終更新

  // ニュース検知
  delistingNewsDetected Boolean @default(false)

  // リレーション
  orders    TradingOrder[]
  positions TradingPosition[]

  createdAt DateTime @default(now())

  @@index([tickerCode])
  @@index([sector])
  @@index([isActive])
  @@index([isRestricted])
}

// 取引設定
model TradingConfig {
  id             String  @id @default(cuid())
  totalBudget    Decimal @db.Decimal(12, 0) // 投資総額（円）
  maxPositions   Int     @default(5) // 最大同時保有数
  maxPositionPct Decimal @default(30) @db.Decimal(5, 2) // 1銘柄あたり最大比率(%)
  maxDailyLossPct Decimal @default(3) @db.Decimal(5, 2) // 日次最大損失率(%)
  isActive       Boolean @default(true) // 取引有効/無効
  peakEquity     Decimal? @db.Decimal(12, 0) // 資産の最高値（ハイウォーターマーク）

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 市場状況評価（毎朝AI判断）
model MarketAssessment {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  nikkeiPrice     Decimal? @db.Decimal(10, 2)
  nikkeiChange    Decimal? @db.Decimal(8, 4) // 前日比%
  sp500Change     Decimal? @db.Decimal(8, 4)
  vix             Decimal? @db.Decimal(8, 2)
  nikkeiVi        Decimal? @db.Decimal(8, 2)
  usdjpy          Decimal? @db.Decimal(8, 4)
  cmeFuturesPrice Decimal? @db.Decimal(10, 2)
  sentiment       String // bullish / neutral / bearish / crisis
  shouldTrade     Boolean // 今日取引すべきか
  reasoning       String  @db.Text // 判断理由

  tradingStrategy String? // day_trade / swing

  // AI選定銘柄（JSON配列）
  selectedStocks Json? // [{ tickerCode, strategy, score, reasoning }]

  // 昼休み再評価（12:15 JST）
  middaySentiment    String?   // 昼AIの生の評価: bullish / neutral / bearish / crisis
  middayReasoning    String?   @db.Text // 昼AIの判断理由
  middayReassessedAt DateTime? // 再評価実行タイムスタンプ
  middayNikkeiPrice  Decimal?  @db.Decimal(10, 2)
  middayNikkeiChange Decimal?  @db.Decimal(8, 4)
  middayVix          Decimal?  @db.Decimal(8, 2)
  middayNikkeiVi     Decimal?  @db.Decimal(8, 2)

  createdAt DateTime @default(now())

  @@unique([date])
  @@index([date(sort: Desc)])
}

// スコアリング記録（候補銘柄 + 即死棄却 + ゴースト追跡）
model ScoringRecord {
  id           String   @id @default(cuid())
  date         DateTime @db.Date
  tickerCode   String

  // 総合
  totalScore   Int
  rank         String   // S / A / B / C

  // カテゴリ別スコア
  technicalScore    Int   // 0-65
  patternScore      Int   // 0-15
  liquidityScore    Int   // 0-10
  fundamentalScore  Int   @default(0) // 0-10

  // カテゴリ内訳（JSON）
  technicalBreakdown   Json   // { rsi, ma, volume, volumeDirection, macd, rs, weeklyTrendPenalty }
  patternBreakdown     Json   // { chart, candlestick }
  liquidityBreakdown   Json   // { tradingValue, spreadProxy, stability }
  fundamentalBreakdown Json?  // { per, pbr, profitability, marketCap }

  // 即死ルール
  isDisqualified    Boolean @default(false)
  disqualifyReason  String? // price_too_high / spread_too_wide / volatility_extreme

  // AIレビュー結果
  aiDecision   String?  // go / no_go
  aiReasoning  String?  @db.Text

  // トレード結果（後から紐づけ）
  tradingOrderId String?  @unique
  tradeResult    String?  // win / loss / no_trade
  profitPct      Decimal? @db.Decimal(8, 4)

  // 逆行ウィナー分析
  contrarianBonus Int @default(0)  // 逆行ボーナスポイント（0-7）
  contrarianWins  Int @default(0)  // 過去90日の逆行勝ち回数

  // Ghost Trading Analysis（偽陰性分析）
  rejectionReason String?                     // below_threshold / ai_no_go / disqualified
  entryPrice      Decimal? @db.Decimal(10, 2) // スコアリング時の株価
  closingPrice        Decimal? @db.Decimal(10, 2) // 大引け後の終値
  ghostProfitPct      Decimal? @db.Decimal(8, 4)  // 仮想損益 %
  ghostAnalysis       String?  @db.Text           // AI後悔分析
  nextDayClosingPrice Decimal? @db.Decimal(10, 2) // 翌営業日の終値
  nextDayProfitPct    Decimal? @db.Decimal(8, 4)  // 翌日騰落率（前日終値比）

  createdAt    DateTime @default(now())

  @@unique([date, tickerCode])
  @@index([date(sort: Desc)])
  @@index([rank])
  @@index([tradeResult])
  @@index([rejectionReason])
}

// 売買注文（シミュレーション）
model TradingOrder {
  id         String @id @default(cuid())
  stockId    String
  stock      Stock  @relation(fields: [stockId], references: [id])
  side       String // buy / sell
  orderType  String // limit / stop_limit / market
  strategy   String // day_trade / swing
  limitPrice      Decimal? @db.Decimal(10, 2) // 指値
  stopPrice       Decimal? @db.Decimal(10, 2) // 逆指値トリガー
  takeProfitPrice Decimal? @db.Decimal(10, 2) // 利確価格
  stopLossPrice   Decimal? @db.Decimal(10, 2) // 損切り価格
  quantity   Int // 株数
  status     String @default("pending") // pending / filled / cancelled / expired
  filledPrice Decimal? @db.Decimal(10, 2)
  filledAt    DateTime?
  reasoning   String @db.Text // 注文理由
  entrySnapshot Json? // 注文作成時のスコア・テクニカル・AI判断

  positionId String?
  position   TradingPosition? @relation(fields: [positionId], references: [id])

  unfilledFollowUp UnfilledOrderFollowUp?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime? // 注文有効期限

  @@index([status])
  @@index([stockId])
  @@index([positionId])
  @@index([createdAt(sort: Desc)])
}

// 保有ポジション
model TradingPosition {
  id              String  @id @default(cuid())
  stockId         String
  stock           Stock   @relation(fields: [stockId], references: [id])
  strategy        String // day_trade / swing
  entryPrice      Decimal @db.Decimal(10, 2)
  quantity        Int
  takeProfitPrice Decimal? @db.Decimal(10, 2)
  stopLossPrice   Decimal? @db.Decimal(10, 2)
  status          String  @default("open") // open / closed
  exitPrice       Decimal? @db.Decimal(10, 2)
  exitedAt        DateTime?
  realizedPnl     Decimal? @db.Decimal(12, 2) // 確定損益

  // スナップショット
  entrySnapshot     Json?                       // 購入時のテクニカル・AI理由・市場環境
  exitSnapshot      Json?                       // 売却時の理由・値動き・市場状況
  maxHighDuringHold Decimal? @db.Decimal(10, 2) // 保有中の最高値
  minLowDuringHold  Decimal? @db.Decimal(10, 2) // 保有中の最安値
  trailingStopPrice Decimal? @db.Decimal(10, 2) // 現在のトレーリングストップ価格
  entryAtr          Decimal? @db.Decimal(10, 2) // エントリー時のATR(14)
  reviewComments    String?  @db.Text           // AIによる振り返り分析

  orders              TradingOrder[]
  defensiveFollowUp   DefensiveExitFollowUp?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([stockId])
  @@index([createdAt(sort: Desc)])
}

// ニュース記事（生データ）
model NewsArticle {
  id          String   @id @default(cuid())
  source      String   // "newsapi" | "google_rss" | "yahoo_finance"
  title       String
  url         String
  publishedAt DateTime
  category    String   // "geopolitical" | "sector" | "stock"
  tickerCode  String?
  sector      String?
  contentHash String   @unique // SHA-256(title|url)

  createdAt DateTime @default(now())

  @@index([publishedAt(sort: Desc)])
  @@index([category])
  @@index([tickerCode])
}

// ニュース分析（AI処理済みサマリー、日次1レコード）
model NewsAnalysis {
  id                    String   @id @default(cuid())
  date                  DateTime @db.Date @unique
  geopoliticalRiskLevel Int      // 1-5
  geopoliticalSummary   String   @db.Text
  marketImpact          String   // "positive" | "neutral" | "negative"
  marketImpactSummary   String   @db.Text
  sectorImpacts         Json     // [{ sector, impact, summary }]
  stockCatalysts        Json     // [{ tickerCode, type, summary }]
  keyEvents             String   @db.Text
  articleCount          Int

  createdAt DateTime @default(now())

  @@index([date(sort: Desc)])
}

// 日次取引サマリー
model TradingDailySummary {
  id             String   @id @default(cuid())
  date           DateTime @db.Date @unique
  totalTrades    Int      @default(0)
  wins           Int      @default(0)
  losses         Int      @default(0)
  totalPnl       Decimal  @default(0) @db.Decimal(12, 2)
  portfolioValue Decimal  @db.Decimal(12, 0) // 時価評価額
  cashBalance    Decimal  @db.Decimal(12, 0) // 残り現金
  aiReview       String?  @db.Text // AIによる振り返り
  decisionAudit  Json?              // 意思決定整合性評価（ghost-review が書き込む）

  createdAt DateTime @default(now())

  @@index([date(sort: Desc)])
}

// 銘柄ステータス変更ログ（監査証跡）
model StockStatusLog {
  id         String   @id @default(cuid())
  tickerCode String
  changeType String   // "jpx_added" | "jpx_removed" | "delisting_set" | "restricted_set" | "news_flag"
  oldValue   String?
  newValue   String?
  source     String   // "jpx_csv" | "jpx_delisting" | "news_collector"
  detail     String?

  createdAt DateTime @default(now())

  @@index([tickerCode])
  @@index([createdAt(sort: Desc)])
}

// コーポレートイベントログ（配当落ち・株式分割の調整記録）
model CorporateEventLog {
  id         String   @id @default(cuid())
  tickerCode String
  eventType  String   // "ex_dividend" | "stock_split"
  eventDate  DateTime @db.Date
  detail     Json?    // { dividendAmount: 15 } or { splitRatio: "1:2", numerator: 1, denominator: 2 }

  // ポジション調整記録
  positionId     String?
  adjustmentType String?  // "stop_loss_adjusted" | "position_split_adjusted"
  beforeValue    Json?    // 調整前の値
  afterValue     Json?    // 調整後の値

  createdAt DateTime @default(now())

  @@index([tickerCode])
  @@index([eventDate(sort: Desc)])
  @@index([eventType])
}

// 日次バックテスト結果（資金帯別）
model BacktestDailyResult {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  conditionKey    String   // "baseline" / "ts_act_1.5" / "score_60" / "atr_0.8" / "trail_0.8" etc.
  conditionLabel  String   // "ベースライン" / "TS起動1.5" etc.
  initialBudget   Int
  maxPrice        Int
  maxPositions    Int
  tickerCount     Int
  totalTrades     Int
  wins            Int
  losses          Int
  winRate         Decimal  @db.Decimal(5, 2)
  profitFactor    Decimal  @db.Decimal(8, 2)
  maxDrawdown     Decimal  @db.Decimal(5, 2)
  sharpeRatio     Decimal? @db.Decimal(8, 2)
  totalPnl        Int
  totalReturnPct  Decimal  @db.Decimal(8, 2)
  avgHoldingDays  Decimal  @db.Decimal(5, 2)
  byRank          Json
  fullResult      Json?
  periodStart     String
  periodEnd       String
  executionTimeMs Int

  createdAt DateTime @default(now())

  @@unique([date, conditionKey])
  @@index([date(sort: Desc)])
}

// ディフェンシブモード妥当性検証（exit後の価格追跡）
model DefensiveExitFollowUp {
  id         String   @id @default(cuid())
  positionId String   @unique
  position   TradingPosition @relation(fields: [positionId], references: [id])
  tickerCode String
  exitDate   DateTime @db.Date
  exitPrice  Decimal  @db.Decimal(10, 2)
  exitReason String   // "crisis" | "bearish"

  // N営業日後の終値
  day1Price  Decimal? @db.Decimal(10, 2)
  day3Price  Decimal? @db.Decimal(10, 2)
  day5Price  Decimal? @db.Decimal(10, 2)

  // 持ち続けた場合の損益%
  day1PnlPct Decimal? @db.Decimal(8, 4)
  day3PnlPct Decimal? @db.Decimal(8, 4)
  day5PnlPct Decimal? @db.Decimal(8, 4)

  isComplete Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isComplete])
  @@index([exitDate(sort: Desc)])
}

// 未約定注文フォローアップ（指値が刺さらなかった注文の事後検証）
model UnfilledOrderFollowUp {
  id         String   @id @default(cuid())
  orderId    String   @unique
  order      TradingOrder @relation(fields: [orderId], references: [id])
  tickerCode String
  strategy   String   // day_trade / swing

  // 注文コンテキスト
  orderDate   DateTime @db.Date
  limitPrice  Decimal  @db.Decimal(10, 2)
  marketPrice Decimal  @db.Decimal(10, 2) // 注文時の市場価格
  gapPct      Decimal  @db.Decimal(8, 4)  // (limitPrice - marketPrice) / marketPrice * 100
  cancelReason String  // expired / cancelled_midday / cancelled_eod

  // N営業日後の終値
  day1Price  Decimal? @db.Decimal(10, 2)
  day3Price  Decimal? @db.Decimal(10, 2)
  day5Price  Decimal? @db.Decimal(10, 2)

  // 指値に到達したか（N営業日目までの安値が指値以下）
  day1ReachedLimit Boolean?
  day3ReachedLimit Boolean?
  day5ReachedLimit Boolean?

  // 仮想損益（指値で買えていた場合のN営業日後損益%）
  day1PnlPct Decimal? @db.Decimal(8, 4)
  day3PnlPct Decimal? @db.Decimal(8, 4)
  day5PnlPct Decimal? @db.Decimal(8, 4)

  isComplete Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isComplete])
  @@index([orderDate(sort: Desc)])
}
