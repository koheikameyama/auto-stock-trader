generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BacktestDailyResult {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  initialBudget   Int
  maxPrice        Int
  maxPositions    Int
  tickerCount     Int
  totalTrades     Int
  wins            Int
  losses          Int
  winRate         Decimal  @db.Decimal(5, 2)
  profitFactor    Decimal  @db.Decimal(8, 2)
  maxDrawdown     Decimal  @db.Decimal(5, 2)
  sharpeRatio     Decimal? @db.Decimal(8, 2)
  totalPnl        Int
  totalReturnPct  Decimal  @db.Decimal(8, 2)
  avgHoldingDays  Decimal  @db.Decimal(5, 2)
  byRank          Json
  fullResult      Json?
  periodStart     String
  periodEnd       String
  executionTimeMs Int
  createdAt       DateTime @default(now())
  conditionKey    String
  conditionLabel  String

  @@unique([date, conditionKey])
  @@index([date(sort: Desc)])
}


model BreakoutWatchlistEntry {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  tickerCode  String
  avgVolume25 Float
  high20      Float
  atr14       Float
  latestClose  Float
  weeklyHigh13 Float?
  createdAt    DateTime @default(now())

  @@unique([date, tickerCode])
  @@index([date(sort: Desc)])
}

model WatchlistEntry {
  id           String   @id @default(cuid())
  date         DateTime @db.Date
  tickerCode   String
  avgVolume25  Float
  atr14        Float
  latestClose  Float
  momentum5d   Float
  weeklyHigh13 Float?
  ma20         Float?   // 20日移動平均（当日朝に計算）
  createdAt    DateTime @default(now())

  @@unique([date, tickerCode])
  @@index([date(sort: Desc)])
}

model CorporateEventLog {
  id             String   @id @default(cuid())
  tickerCode     String
  eventType      String
  eventDate      DateTime @db.Date
  detail         Json?
  positionId     String?
  adjustmentType String?
  beforeValue    Json?
  afterValue     Json?
  createdAt      DateTime @default(now())

  @@index([eventDate(sort: Desc)])
  @@index([eventType])
  @@index([tickerCode])
}

model DefensiveExitFollowUp {
  id              String          @id @default(cuid())
  positionId      String          @unique
  tickerCode      String
  exitDate        DateTime        @db.Date
  exitPrice       Decimal         @db.Decimal(10, 2)
  exitReason      String
  day1Price       Decimal?        @db.Decimal(10, 2)
  day3Price       Decimal?        @db.Decimal(10, 2)
  day5Price       Decimal?        @db.Decimal(10, 2)
  day1PnlPct      Decimal?        @db.Decimal(8, 4)
  day3PnlPct      Decimal?        @db.Decimal(8, 4)
  day5PnlPct      Decimal?        @db.Decimal(8, 4)
  isComplete      Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime     @updatedAt
  position        TradingPosition @relation(fields: [positionId], references: [id])

  @@index([exitDate(sort: Desc)])
  @@index([isComplete])
}

model HoldingScoreRecord {
  id                    String          @id @default(cuid())
  date                  DateTime        @db.Date
  positionId            String
  tickerCode            String
  totalScore            Int
  holdingRank           String
  trendQualityScore     Int
  riskQualityScore      Int
  sectorMomentumScore   Int
  trendQualityBreakdown Json
  riskQualityBreakdown  Json
  gateResult            Json
  alerts                Json?
  currentPrice          Decimal         @db.Decimal(10, 2)
  unrealizedPnlPct      Decimal         @db.Decimal(8, 4)
  holdingDays           Int
  actionTaken           String?
  createdAt             DateTime        @default(now())
  position              TradingPosition @relation(fields: [positionId], references: [id])

  @@unique([date, positionId])
  @@index([positionId])
}

model MarketAssessment {
  id              String   @id @default(cuid())
  date            DateTime @unique @db.Date
  nikkeiPrice     Decimal? @db.Decimal(10, 2)
  nikkeiChange    Decimal? @db.Decimal(8, 4)
  sp500Change     Decimal? @db.Decimal(8, 4)
  vix             Decimal? @db.Decimal(8, 2)
  usdjpy          Decimal? @db.Decimal(8, 4)
  cmeFuturesPrice Decimal? @db.Decimal(10, 2)
  sentiment       String
  shouldTrade     Boolean
  reasoning       String
  selectedStocks  Json?
  createdAt       DateTime @default(now())
  nikkeiVi        Decimal? @db.Decimal(8, 2)
  nasdaqChange    Decimal? @db.Decimal(8, 4)
  dowChange       Decimal? @db.Decimal(8, 4)
  soxChange       Decimal? @db.Decimal(8, 4)
  breadth          Decimal? @db.Decimal(5, 4)
  cmeDivergencePct Decimal? @db.Decimal(8, 4)

  @@index([date(sort: Desc)])
}

model NewsArticle {
  id          String   @id @default(cuid())
  source      String
  title       String
  url         String
  publishedAt DateTime
  category    String
  contentHash String   @unique
  createdAt   DateTime @default(now())

  @@index([category])
  @@index([publishedAt(sort: Desc)])
}

model ScoringRecord {
  id                    String   @id @default(cuid())
  date                  DateTime @db.Date
  tickerCode            String
  totalScore            Int
  isDisqualified        Boolean  @default(false)
  disqualifyReason      String?
  tradingOrderId        String?  @unique
  tradeResult           String?
  profitPct             Decimal? @db.Decimal(8, 4)
  createdAt             DateTime @default(now())
  closingPrice          Decimal? @db.Decimal(10, 2)
  entryPrice            Decimal? @db.Decimal(10, 2)
  ghostAnalysis         String?
  ghostProfitPct        Decimal? @db.Decimal(8, 4)
  rejectionReason       String?
  contrarianBonus       Int      @default(0)
  contrarianWins        Int      @default(0)
  nextDayClosingPrice   Decimal? @db.Decimal(10, 2)
  nextDayProfitPct      Decimal? @db.Decimal(8, 4)
  entryTimingBreakdown  Json
  entryTimingScore      Int
  riskQualityBreakdown  Json
  riskQualityScore      Int
  trendQualityBreakdown Json
  trendQualityScore     Int
  sectorMomentumScore   Int      @default(0)
  ghost5DayProfitPct    Decimal? @db.Decimal(8, 4)
  ghost10DayProfitPct   Decimal? @db.Decimal(8, 4)

  @@unique([date, tickerCode])
  @@index([date(sort: Desc)])
  @@index([rejectionReason])
  @@index([tradeResult])
}

model Stock {
  id               String            @id @default(cuid())
  tickerCode       String            @unique
  name             String
  market           String
  sector           String?
  marketCap        Decimal?
  dividendYield    Decimal?
  pbr              Decimal?          @db.Decimal(8, 2)
  per              Decimal?          @db.Decimal(8, 2)
  roe              Decimal?          @db.Decimal(8, 4)
  eps              Decimal?          @db.Decimal(12, 2)
  isProfitable     Boolean?
  latestPrice      Decimal?          @db.Decimal(12, 2)
  latestVolume     BigInt?
  dailyChangeRate  Decimal?          @db.Decimal(8, 2)
  weekChangeRate   Decimal?          @db.Decimal(8, 2)
  volatility       Decimal?          @db.Decimal(8, 2)
  atr14            Decimal?          @db.Decimal(12, 2)
  latestPriceDate  DateTime?         @db.Date
  priceUpdatedAt   DateTime?
  fetchFailCount   Int               @default(0)
  isDelisted       Boolean           @default(false)
  createdAt        DateTime          @default(now())
  delistingDate    DateTime?         @db.Date
  isActive         Boolean           @default(true)
  isRestricted     Boolean           @default(false)
  jpxLastSyncDate  DateTime?         @db.Date
  jpxSectorCode    String?
  jpxSectorName    String?
  statusUpdatedAt  DateTime?
  supervisionFlag  String?
  tradingHaltFlag  Boolean           @default(false)
  nextEarningsDate DateTime?         @db.Date
  exDividendDate   DateTime?         @db.Date
  dividendPerShare Decimal?          @db.Decimal(10, 2)
  orders     TradingOrder[]
  positions  TradingPosition[]

  @@index([isActive])
  @@index([isRestricted])
  @@index([sector])
  @@index([tickerCode])
}

model StockDailyBar {
  id         String   @id @default(cuid())
  tickerCode String
  date       DateTime @db.Date
  open       Float
  high       Float
  low        Float
  close      Float
  volume     BigInt
  market     String   @default("JP") // "JP" | "US" | "INDEX"

  @@unique([tickerCode, date])
  @@index([tickerCode, date(sort: Desc)])
  @@index([market])
}

model StockStatusLog {
  id         String   @id @default(cuid())
  tickerCode String
  changeType String
  oldValue   String?
  newValue   String?
  source     String
  detail     String?
  createdAt  DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([tickerCode])
}

model TradingConfig {
  id                String    @id @default(cuid())
  totalBudget       Decimal   @db.Decimal(12, 0)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  peakEquity        Decimal?  @db.Decimal(12, 0)
  realizedPnl       Decimal   @default(0) @db.Decimal(12, 0)
  loginLockedUntil    DateTime? // ロック解除予定時刻（nullなら正常）
  loginLockReason     String?   // ロック理由メッセージ
  loginLockOccurredAt DateTime? // ロック発生日時（パターン分析用・クリアしない）
  loginArmedUntil     DateTime? // ログイン承認の有効期限（この時刻までに login() が走ればAPI呼び出しを許可）
  loginArmedAt        DateTime? // 承認ボタン押下日時（監査・デバッグ用）
}

model TradingDailySummary {
  id             String   @id @default(cuid())
  date           DateTime @unique @db.Date
  totalTrades    Int      @default(0)
  wins           Int      @default(0)
  losses         Int      @default(0)
  totalPnl       Decimal  @default(0) @db.Decimal(12, 2)
  portfolioValue Decimal  @db.Decimal(12, 0)
  cashBalance    Decimal  @db.Decimal(12, 0)
  aiReview       String?
  createdAt      DateTime @default(now())

  @@index([date(sort: Desc)])
}

model TradingOrder {
  id                    String                 @id @default(cuid())
  stockId               String
  side                  String
  orderType             String
  strategy              String
  limitPrice            Decimal?               @db.Decimal(10, 2)
  stopPrice             Decimal?               @db.Decimal(10, 2)
  quantity              Int
  status                String                 @default("pending")
  filledPrice           Decimal?               @db.Decimal(10, 2)
  filledAt              DateTime?
  reasoning             String
  positionId            String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime     @updatedAt
  expiresAt             DateTime?
  entrySnapshot         Json?
  stopLossPrice         Decimal?               @db.Decimal(10, 2)
  takeProfitPrice       Decimal?               @db.Decimal(10, 2)
  brokerBusinessDay     String?
  brokerOrderId         String?
  brokerStatus          String?
  referencePrice        Decimal?               @db.Decimal(10, 2)
  slippageBps           Int?
  position              TradingPosition?       @relation(fields: [positionId], references: [id])
  stock                 Stock                  @relation(fields: [stockId], references: [id])
  unfilledFollowUp      UnfilledOrderFollowUp?

  @@index([brokerOrderId, brokerBusinessDay])
  @@index([createdAt(sort: Desc)])
  @@index([positionId])
  @@index([status])
  @@index([stockId])
}

model TradingPosition {
  id                        String                 @id @default(cuid())
  stockId                   String
  strategy                  String
  entryPrice                Decimal                @db.Decimal(10, 2)
  quantity                  Int
  takeProfitPrice           Decimal?               @db.Decimal(10, 2)
  stopLossPrice             Decimal?               @db.Decimal(10, 2)
  status                    String                 @default("open")
  exitPrice                 Decimal?               @db.Decimal(10, 2)
  exitedAt                  DateTime?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime     @updatedAt
  entrySnapshot             Json?
  exitSnapshot              Json?
  maxHighDuringHold         Decimal?               @db.Decimal(10, 2)
  minLowDuringHold          Decimal?               @db.Decimal(10, 2)
  // エントリー品質追跡（EODバッチで補完）
  nextDayOpenPrice           Float?
  nextDayOpenGapPct          Float?
  reviewComments            String?
  // 決済後の株価追跡（EODバッチで補完）
  postExitClose5d           Float?
  postExitClose10d          Float?
  postExitMaxHigh10d        Float?
  postExitMinLow10d         Float?
  postExitReturn5dPct       Float?
  postExitReturn10dPct      Float?
  postExitMaxHighPct        Float?
  postExitMinLowPct         Float?
  entryAtr                  Decimal?               @db.Decimal(10, 2)
  trailingStopPrice         Decimal?               @db.Decimal(10, 2)
  holdingScoreTrailOverride Decimal?               @db.Decimal(5, 2)
  slBrokerBusinessDay       String?
  slBrokerOrderId           String?
  // VIXレジームスケーリング情報（エントリー時のMarketAssessment由来）
  vixAtEntry                Decimal?               @db.Decimal(6, 2)
  regimeLevel               String?
  regimeScale               Decimal?               @db.Decimal(4, 3)
  appliedRiskPct            Decimal?               @db.Decimal(6, 3)
  defensiveFollowUp         DefensiveExitFollowUp?
  holdingScores             HoldingScoreRecord[]
  orders                    TradingOrder[]
  stock                     Stock                  @relation(fields: [stockId], references: [id])

  @@index([createdAt(sort: Desc)])
  @@index([status])
  @@index([stockId])
}

model TradingWeeklySummary {
  id             String   @id @default(cuid())
  weekStart      DateTime @db.Date
  weekEnd        DateTime @unique @db.Date
  tradingDays    Int
  totalTrades    Int      @default(0)
  wins           Int      @default(0)
  losses         Int      @default(0)
  totalPnl       Decimal  @default(0) @db.Decimal(12, 2)
  portfolioValue Decimal  @db.Decimal(12, 0)
  cashBalance    Decimal  @db.Decimal(12, 0)
  aiReview       Json
  createdAt      DateTime @default(now())

  @@index([weekEnd(sort: Desc)])
}

model UnfilledOrderFollowUp {
  id               String       @id @default(cuid())
  orderId          String       @unique
  tickerCode       String
  strategy         String
  orderDate        DateTime     @db.Date
  limitPrice       Decimal      @db.Decimal(10, 2)
  marketPrice      Decimal      @db.Decimal(10, 2)
  gapPct           Decimal      @db.Decimal(8, 4)
  cancelReason     String
  day1Price        Decimal?     @db.Decimal(10, 2)
  day3Price        Decimal?     @db.Decimal(10, 2)
  day5Price        Decimal?     @db.Decimal(10, 2)
  day1ReachedLimit Boolean?
  day3ReachedLimit Boolean?
  day5ReachedLimit Boolean?
  day1PnlPct       Decimal?     @db.Decimal(8, 4)
  day3PnlPct       Decimal?     @db.Decimal(8, 4)
  day5PnlPct       Decimal?     @db.Decimal(8, 4)
  isComplete       Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  order            TradingOrder @relation(fields: [orderId], references: [id])

  @@index([isComplete])
  @@index([orderDate(sort: Desc)])
}

model EarningsDate {
  id         String   @id @default(cuid())
  tickerCode String
  date       DateTime @db.Date
  createdAt  DateTime @default(now())

  @@unique([tickerCode, date])
  @@index([tickerCode, date(sort: Desc)])
  @@index([date])
}

model BrokerSession {
  id                String   @id @default(cuid())
  env               String   @unique // "demo" or "production"
  urlRequest        String
  urlMaster         String
  urlPrice          String
  urlEvent          String
  urlEventWebSocket String
  loginAt           DateTime
  updatedAt         DateTime @updatedAt
}

model IntraDayMaPullbackSignal {
  id             Int       @id @default(autoincrement())
  date           DateTime  @db.Date
  tickerCode     String
  detectedAt     DateTime
  ma20           Float
  detectedPrice  Float
  closePrice     Float?
  stopLossPrice  Float
  atr14          Float
  touchCount     Int       @default(1)
  lastTouchAt    DateTime?
  lastTouchPrice Float?
  createdAt      DateTime  @default(now())

  @@index([date(sort: Desc)])
  @@unique([date, tickerCode])
}

model RejectedSignal {
  id           String   @id @default(cuid())
  ticker       String
  strategy     String
  rejectedAt   DateTime
  reason       String
  reasonLabel  String
  entryPrice   Float
  close5d      Float?
  close10d     Float?
  return5dPct  Float?
  return10dPct Float?
  createdAt    DateTime @default(now())

  @@index([rejectedAt(sort: Desc)])
  @@index([ticker])
}
