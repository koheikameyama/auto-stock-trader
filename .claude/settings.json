{
  "permissions": {
    "allow": [
      "mcp__linear-server__get_issue",
      "Bash(npx vitest run:*)",
      "Bash(npx eslint:*)",
      "Bash(node -c:*)",
      "Bash(gh api:*)",
      "Bash(git fetch:*)",
      "Bash(npm install:*)",
      "Bash(npm test:*)",
      "Bash(npx husky init)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun x gh-setup-hooks",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
